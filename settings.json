	// #endregion
	// #region CSS Language Features
	// #region    CSS
	"css.lint.unknownAtRules": "ignore",
	// #endregion
	// #region    LESS
	// #endregion
	// #region    SCSS (Sass)
	// #endregion
	// #endregion
	// #region Dev Containers
	// #endregion
	// #region EditorConfig
	// #endregion
	// #region Emmet
	// #endregion
	// #region Error Lens
	"errorLens.enableOnDiffView": true,
	"errorLens.gutterIconSet": "defaultOutline",
	"errorLens.messageTemplate": "$severity $message ($code)",
	"errorLens.respectUpstreamEnabled": {
		"statusBar": true
	},
	"errorLens.scrollbarHackEnabled": true,
	"errorLens.severityText": ["⛔", "⚠️", "ℹ️", "❇️"],
	// #endregion
	// #region GHE.com & GitHub Enterprise Server Authentication
	// #endregion
	// #region Git
	"git.autofetch": true,
	"git.confirmSync": false,
	"git.enableSmartCommit": true,
	"git.fetchOnPull": true,
	"git.mergeEditor": true,
	"git.openRepositoryInParentFolders": "never",
	// #endregion
	// #region GitHub
	// #endregion
	// #region GitHub Actions
	// #endregion
	// #region GitHub Copilot Chat
	"github.copilot.chat.agent.autoFix": true,
	"github.copilot.chat.anthropic.thinking.budgetTokens": 32000,
	"github.copilot.enable": {
		"*": true,
		"plaintext": true,
		"markdown": true,
		"scminput": false
	},
	"github.copilot.nextEditSuggestions.enabled": true,
	"github.copilot.chat.copilotMemory.enabled": true,
	"github.copilot.chat.anthropic.tools.websearch.enabled": true,
	"github.copilot.chat.anthropic.tools.websearch.maxUses": 20,
	"github.copilot.chat.githubMcpServer.enabled": true,
	"github.copilot.chat.languageContext.inline.typescript.enabled": true,
	// #endregion
	// #region GitHub Pull Requests
	// #endregion
	// #region GitHub Repositories
	// #endregion
	// #region Grunt
	// #endregion
	// #region Gulp
	// #endregion
